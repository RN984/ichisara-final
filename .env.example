# このファイルをコピーして .env を作成し、各値を設定してください。
# VITE_ 接頭辞のキーは公開ビルドに埋め込まれます。
# 秘匿が必要なものは Google Cloud Console 側で必ず制限をかけること。

VITE_SHEET_API=
VITE_SHEET_ID=

# Google Drive API キー（必ず HTTPリファラー制限 + Drive APIのみに制限すること）
VITE_DRIVE_API_KEY=

# Drive フォルダID
VITE_DRIVE_THUMB_FOLDER=
VITE_DRIVE_PDF_FOLDER=
VITE_DRIVE_INSTA_FOLDER=
